# ============================================================
#  ITCareerGuide AI — .gitignore
# ============================================================

# ── OS / System files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor & IDE files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ── Node (if any tooling is added later) ─────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Docker build artifacts ────────────────────────────────────
*.tar
docker-compose.override.yml

# ── Environment & secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.cert

# ── Build / dist outputs ─────────────────────────────────────
dist/
build/
out/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Coverage & test artifacts ────────────────────────────────
coverage/
.nyc_output/

# ── Temporary files ──────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.cache
