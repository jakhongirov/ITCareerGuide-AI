# ============================================================
#  ITCareerGuide AI — .dockerignore
#  Keeps Docker build context lean & secrets out of the image
# ============================================================

# ── Git ──────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker files themselves (no need to copy into image) ─────
Dockerfile
docker-compose.yml
.dockerignore

# ── OS / System files ────────────────────────────────────────
.DS_Store
Thumbs.db
*.orig

# ── Editor & IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Node / package artifacts ─────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment & secrets ────────────────────────────────────
.env
.env.*
*.key
*.pem
*.cert
*.secret

# ── Build / dist outputs ─────────────────────────────────────
dist/
build/
out/

# ── Logs & temp files ────────────────────────────────────────
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.cache

# ── Test artifacts ───────────────────────────────────────────
coverage/
.nyc_output/
tests/
